# =============================================================================
# project_enterpriseweb — variables de entorno
# Copia este archivo como `.env.local` (NO se versiona) y rellena cada valor.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos — PostgreSQL (Neon recomendado)
# DATABASE_URL: cadena POOLED (host con -pooler). La usa Next.js en runtime.
# DIRECT_URL:   cadena DIRECTA (sin -pooler).     La usa Prisma en migraciones.
# -----------------------------------------------------------------------------
DATABASE_URL=
DIRECT_URL=

# -----------------------------------------------------------------------------
# NextAuth
# NEXTAUTH_URL: URL pública en este entorno. En local: http://localhost:3000
# NEXTAUTH_SECRET: secreto para firmar los JWT. Generar con: openssl rand -base64 32
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# OAuth — GitHub
# Crear en: https://github.com/settings/developers → New OAuth App
#   Homepage URL:        http://localhost:3000
#   Authorization URL:   http://localhost:3000/api/auth/callback/github
# -----------------------------------------------------------------------------
GITHUB_ID=
GITHUB_SECRET=

# -----------------------------------------------------------------------------
# Firebase (proyecto en https://console.firebase.google.com)
# Authentication → Sign-in method → habilitar "Email/Password"
# Project settings → Your apps → Web app → SDK config
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
